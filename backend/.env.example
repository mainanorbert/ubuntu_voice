# Retrieval
# Source: local app tuning.
# Use: number of chunks retrieved for each RAG query.
RAG_TOP_K=5

# OpenRouter / model access
# Source: OpenRouter dashboard.
# Use: chat and evaluation model API access.
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4.1-mini

# Clerk auth
# Source: Clerk dashboard.
# Use: verify sessions and allow trusted frontend origins.
CLERK_JWKS_URL=https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
CLERK_SECRET_KEY=your_clerk_secret_key
CLERK_AUTHORIZED_PARTIES=https://your-frontend.example.com,http://localhost:3000

# API access control
# Source: deployed frontend origins.
# Use: allow browser requests to the backend.
CORS_ALLOWED_ORIGINS=https://your-frontend.example.com,http://localhost:3000

# Database
# Source: Aiven or your PostgreSQL provider.
# Use: primary backend database connection string.
EIVEN_SERVICE_URL=postgresql+psycopg2://user:password@host:5432/database

# OpenAI-compatible embeddings or provider access
# Source: OpenAI dashboard.
# Use: API access where OpenAI credentials are required by your setup.
OPENAI_API_KEY=your_openai_api_key

# Supabase storage
# Source: Supabase project settings.
# Use: backend document storage and bucket access.
SUPABASE_KEY=your_supabase_service_key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_BUCKET=documents

# Email providers
# Source: SendGrid and Resend dashboards.
# Use: outbound email delivery for approved workflows.
SENDGRID_API_KEY=your_sendgrid_api_key
RESEND_API_KEY=your_resend_api_key

# Twilio messaging
# Source: Twilio console.
# Use: WhatsApp replies and SMS notifications.
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+15551234567
TWILIO_SMS_TO_NUMBER=+15557654321
TWILIO_SMS_FROM_NUMBER=+15551234567

# Pushover alerts
# Source: Pushover app settings.
# Use: push notification delivery for alert workflows.
PUSHOVER_TOKEN=your_pushover_app_token
PUSHOVER_USER=your_pushover_user_key
PUSHOVER_URL=https://api.pushover.net/1/messages.json

# Evaluation debugging
# Source: local developer choice.
# Use: print evaluator comparison inputs during debugging.
EVALUATION_DEBUG_COMPARISONS=false
